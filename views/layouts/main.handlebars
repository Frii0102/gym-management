<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Gym Management</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; background: #f5f5f5; }
        nav { background: #333; padding: 10px 20px; margin-bottom: 20px; }
        nav a { color: white; margin-right: 15px; text-decoration: none; }
        nav a:hover { color: #4CAF50; }
        .content { padding: 20px; }
        table { width: 100%; border-collapse: collapse; background: white; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background: #4CAF50; color: white; }
        form { background: white; padding: 20px; margin-top: 20px; max-width: 500px; }
        input { margin: 5px 0 10px 0; padding: 8px; width: 100%; box-sizing: border-box; }
        button { background: #4CAF50; color: white; padding: 10px 20px; border: none; cursor: pointer; }
    </style>
</head>
<body>
<nav>
    <a href="/">Головна</a>
    <a href="/users">Користувачі</a>
    <a href="/trainers">Тренери</a>
    <a href="/locations">Локації</a>
    <a href="/trainings">Тренування</a>
    <a href="/bookings">Записи</a>
    <a href="/subscriptions">Абонементи</a>
    <a href="/payments">Оплати</a>
    <a href="/reviews">Відгуки</a>
</nav>
<div class="content">
    {{{body}}}
</div>
</body>
</html>