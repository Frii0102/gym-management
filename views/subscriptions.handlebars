<h2>Абонементи</h2>

<div class="card p-4 mb-4" style="max-width: 950px;">
    <h4 class="mb-4">Робота з Excel</h4>

    <div class="row g-3 align-items-end">
        <div class="col-md-auto">
            <a href="/subscriptions/export" class="btn btn-success">Експорт в Excel</a>
        </div>

        <div class="col-md">
            <form action="/subscriptions/import" method="POST" enctype="multipart/form-data"
                  style="background: none; box-shadow: none; padding: 0; margin: 0; max-width: none;">
                <div class="row g-3 align-items-end">
                    <div class="col-md-8">
                        <label for="excelFile" class="form-label">Оберіть Excel-файл</label>
                        <input id="excelFile" class="form-control" type="file" name="excelFile" accept=".xlsx,.xls" required>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-success w-100">Імпорт з Excel</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead>
    <tr>
        <th>ID</th>
        <th>Користувач</th>
        <th>Тип</th>
        <th>Початок</th>
        <th>Кінець</th>
    </tr>
    </thead>
    <tbody>
    {{#each subscriptions}}
        <tr>
            <td>{{subscription_id}}</td>
            <td>{{user_name}}</td>
            <td>{{type}}</td>
            <td>{{formatDate start_date}}</td>
            <td>{{formatDate end_date}}</td>
        </tr>
    {{/each}}
    </tbody>
</table>

<h3>Додати абонемент</h3>
<form method="POST" action="/subscriptions">
    <input name="user_id" placeholder="ID користувача" required>
    <input name="type" placeholder="Тип (monthly/annual)" required>
    <input name="start_date" type="date" required>
    <input name="end_date" type="date" required>
    <button type="submit">Додати</button>
</form>