<h2>Тренування</h2>

<div class="card p-4 mb-4">
    <h3 class="mb-3" style="margin-top: 0;">Список тренувань</h3>

    <table class="table table-striped table-bordered mb-0">
        <thead>
        <tr>
            <th>Назва</th>
            <th>Тренер</th>
            <th>Локація</th>
            <th>Початок</th>
            <th>Тривалість</th>
            <th>Місць</th>
        </tr>
        </thead>
        <tbody>
        {{#each trainings}}
            <tr>
                <td>{{title}}</td>
                <td>{{trainer_name}}</td>
                <td>{{location_name}}</td>
                <td>{{formatDate start_time}}</td>
                <td>{{duration_min}} хв</td>
                <td>{{capacity}}</td>
            </tr>
        {{/each}}
        </tbody>
    </table>
</div>

{{#if (isAdmin user)}}
    <div class="card p-4">
        <h3 class="mb-3" style="margin-top: 0;">Додати тренування</h3>

        <form method="POST" action="/trainings" style="max-width: none; background: none; box-shadow: none; padding: 0; margin: 0;">
            <div class="mb-3">
                <label class="form-label">Назва</label>
                <input name="title" class="form-control" placeholder="Назва тренування" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Тренер</label>
                <select name="trainer_id" class="form-control" required>
                    <option value="">Оберіть тренера</option>
                    {{#each trainers}}
                        <option value="{{trainer_id}}">{{full_name}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Локація</label>
                <select name="location_id" class="form-control" required>
                    <option value="">Оберіть локацію</option>
                    {{#each locations}}
                        <option value="{{location_id}}">{{name}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Початок</label>
                <input name="start_time" type="datetime-local" class="form-control" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Тривалість</label>
                <input name="duration_min" type="number" class="form-control" placeholder="Тривалість у хвилинах" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Кількість місць</label>
                <input name="capacity" type="number" class="form-control" placeholder="Кількість місць" required>
            </div>

            <button type="submit" class="btn btn-success">Додати тренування</button>
        </form>
    </div>
{{/if}}