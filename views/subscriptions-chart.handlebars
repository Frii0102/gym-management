<h2>Діаграма абонементів за типом</h2>

<div style="max-width: 900px; margin: 30px auto;">
    <canvas id="subscriptionsChart"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const chartData = {{{chartData}}}

    const labels = chartData.map(item => item.type)
    const counts = chartData.map(item => item.count)

    const ctx = document.getElementById('subscriptionsChart').getContext('2d')

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Кількість абонементів',
                data: counts,
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                title: {
                    display: true,
                    text: 'Кількість абонементів за типом'
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        precision: 0
                    }
                }
            }
        }
    })
</script>