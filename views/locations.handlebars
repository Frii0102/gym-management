<h2>Локації</h2>

<div class="card p-4 mb-4">
    <h3 class="mb-3" style="margin-top: 0;">Список локацій</h3>

    <table class="table table-striped table-bordered mb-0">
        <thead>
        <tr>
            <th>Назва</th>
            <th>Адреса</th>
            <th>Місто</th>
        </tr>
        </thead>
        <tbody>
        {{#each locations}}
            <tr>
                <td>{{name}}</td>
                <td>{{address}}</td>
                <td>{{city}}</td>
            </tr>
        {{/each}}
        </tbody>
    </table>
</div>

{{#if (isAdmin user)}}
    <div class="card p-4">
        <h3 class="mb-3" style="margin-top: 0;">Додати локацію</h3>

        <form method="POST" action="/locations" style="max-width: none; background: none; box-shadow: none; padding: 0; margin: 0;">
            <div class="mb-3">
                <label class="form-label">Назва</label>
                <input name="name" class="form-control" placeholder="Назва локації" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Адреса</label>
                <input name="address" class="form-control" placeholder="Адреса" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Місто</label>
                <input name="city" class="form-control" placeholder="Місто" required>
            </div>

            <button type="submit" class="btn btn-success">Додати локацію</button>
        </form>
    </div>
{{/if}}