<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gym Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .content-wrap {
            flex: 1;
        }

        .navbar {
            background-color: #212529 !important;
        }

        .navbar-brand {
            color: white !important;
            font-weight: bold;
            font-size: 1.3rem;
        }

        .nav-link {
            color: white !important;
            margin: 0 5px;
        }

        .nav-link:hover {
            color: #adb5bd !important;
        }

        .table thead {
            background-color: #1f3a5f;
            color: white;
        }

        .btn-success {
            background-color: #1f3a5f;
            border-color: #1f3a5f;
            color: white;
        }

        .btn-success:hover {
            background-color: #162b46;
            border-color: #162b46;
            color: white;
        }

        .card {
            border: none;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        h2 {
            color: #212529;
            margin-bottom: 20px;
            font-weight: 600;
        }

        h3 {
            color: #495057;
            margin-top: 30px;
            margin-bottom: 15px;
        }

        footer {
            background-color: #212529;
            color: #adb5bd;
            padding: 20px 0;
        }

        form {
            max-width: 500px;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        select {
            display: block;
            width: 100%;
            padding: 8px;
            margin-bottom: 10px;
            border: 1px solid #ced4da;
            border-radius: 4px;
        }

        input {
            display: block;
            width: 100%;
            padding: 8px;
            margin-bottom: 10px;
            border: 1px solid #ced4da;
            border-radius: 4px;
        }

        button[type="submit"] {
            background-color: #1f3a5f;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            width: 100%;
        }

        button[type="submit"]:hover {
            background-color: #162b46;
        }

        .form-control {
            width: 100% !important;
            margin-bottom: 0 !important;
        }

        .form-label {
            font-weight: 500;
            margin-bottom: 6px;
        }

        .user-badge {
            color: #adb5bd !important;
            white-space: nowrap;
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
        <a class="navbar-brand" href="/">💪 Gym Management</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            {{#if user}}
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" href="/">Головна</a></li>

                    {{#if (isAdmin user)}}
                        <li class="nav-item"><a class="nav-link" href="/users">Користувачі</a></li>
                    {{/if}}

                    <li class="nav-item"><a class="nav-link" href="/trainers">Тренери</a></li>
                    <li class="nav-item"><a class="nav-link" href="/locations">Локації</a></li>
                    <li class="nav-item"><a class="nav-link" href="/trainings">Тренування</a></li>

                    {{#if (isAdmin user)}}
                        <li class="nav-item"><a class="nav-link" href="/bookings">Записи</a></li>
                        <li class="nav-item"><a class="nav-link" href="/subscriptions">Абонементи</a></li>
                        <li class="nav-item"><a class="nav-link" href="/subscriptions/chart">Діаграма</a></li>
                        <li class="nav-item"><a class="nav-link" href="/payments">Оплати</a></li>
                    {{/if}}

                    <li class="nav-item"><a class="nav-link" href="/reviews">Відгуки</a></li>

                    <li class="nav-item">
                        <span class="nav-link user-badge">{{user.full_name}} ({{user.role}})</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/logout">Вийти</a>
                    </li>
                </ul>
            {{else}}
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/login">Вхід</a></li>
                </ul>
            {{/if}}
        </div>
    </div>
</nav>

<div class="content-wrap">
    <div class="container mt-4">
        {{{body}}}
    </div>
</div>

<footer>
    <div class="container text-center">
        <p class="mb-0">© 2026 Gym Management System — Венчак Ілона, К26</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>